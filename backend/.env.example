# SoSoValue OpenAPI key — get one at https://sosovalue-1.gitbook.io/sosovalue-api-doc/setting-up-your-api-key
SOSOVALUE_API_KEY=

# Optional: override the SoSoValue base URL or cache TTL.
# SOSOVALUE_BASE_URL=https://openapi.sosovalue.com/openapi/v1
# SOSOVALUE_CACHE_TTL_S=60
# SOSOVALUE_TIMEOUT_S=8

# Groq API key for basket reasoning generation (https://console.groq.com)
GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile

# SoDEX gateway. Defaults to testnet so the demo runs end-to-end without auth.
# Mainnet: https://mainnet-gw.sodex.dev
SODEX_BASE_URL=https://testnet-gw.sodex.dev/api/v1
# SODEX_TIMEOUT_S=5
# SODEX_CACHE_TTL_S=10

# SoDEX EIP-712 execution (Wave 2 — required for live order placement)
# Get these from https://testnet.sodex.dev → Profile → API Keys
SODEX_PRIVATE_KEY=
SODEX_ADDRESS=
SODEX_ACCOUNT_ID=
SODEX_CHAIN_ID=138565

# SQLite database path (default: sosovault.db in working directory)
SOVAULT_DB_PATH=sosovault.db

# CORS origins (comma-separated). Use the deployed frontend URL in prod.
CORS_ALLOW_ORIGINS=*

# Server port
PORT=3001

# SoSoValue OpenAPI key (required)
SOSOVALUE_API_KEY=

# Groq LLM for AI reasoning (optional — falls back to deterministic templates)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# SoDEX execution (optional — falls back to read-only quotes)
SODEX_PRIVATE_KEY=
SODEX_ADDRESS=
SODEX_ACCOUNT_ID=
SODEX_CHAIN_ID=138565
SODEX_BASE_URL=https://testnet-gw.sodex.dev
SODEX_TIMEOUT_S=15

# Server
PORT=3001
CORS_ALLOW_ORIGINS=*

# Database
SOVAULT_DB_PATH=sosovault.db
